    {
      "name": "3. Peminjaman (Borrowing)",
      "description": "Borrowing and returning books.\nIncludes multi-step validation, stock management, and concurrency protection.",
      "item": [
        {
          "name": "3.1 Create Peminjaman (borrow 2 books)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Peminjaman berhasil', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.message).to.eql('Peminjaman berhasil');",
                  "    pm.expect(data.data).to.have.property('id');",
                  "    pm.expect(data.data).to.have.property('detail_peminjaman');",
