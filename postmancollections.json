{
  "info": {
    "name": "Perpustakaan RESTful API",
    "description": "Complete API collection for Sistem Informasi Manajemen Perpustakaan.\n\n## How to Use\n1. Run endpoints in order from top to bottom (Register Admin → Login Admin → ...)\n2. Bearer token is automatically saved after Register or Login.\n3. Created resource IDs (buku_id, peminjaman_id) are auto-captured for use in subsequent requests.\n4. Every endpoint includes test scripts that validate the response.\n\n## Roles\n- **admin** — Full access (CRUD Buku, manage Peminjaman)\n- **petugas** — Same as admin for Buku CRUD\n- **anggota** — Can only borrow/return books and view own data",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          ""
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          ""
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_email",
      "value": "admin@perpustakaan.com",
      "type": "string"
    },
    {
      "key": "admin_password",
      "value": "password123",
      "type": "string"
    },
    {
      "key": "anggota_email",
      "value": "anggota@perpustakaan.com",
      "type": "string"
    },
    {
      "key": "anggota_password",
      "value": "password123",
      "type": "string"
    },
    {
      "key": "anggota_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "buku_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "buku_id_2",
      "value": "",
      "type": "string"
    },
    {
      "key": "kategori_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "peminjaman_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "description": "Authentication endpoints: Register, Login, Logout.\nRun Register Admin first, then Login Admin to auto-save the bearer token.",
      "item": [
        {
          "name": "1.1 Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains access_token', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.have.property('access_token');",
                  "    pm.expect(data.token_type).to.eql('Bearer');",
                  "    pm.expect(data.user.role).to.eql('admin');",
                  "});",
                  "",
                  "// Auto-save token",
                  "var data = pm.response.json();",
                  "if (data.access_token) {",
                  "    pm.collectionVariables.set('token', data.access_token);",
                  "    console.log('✅ Admin token saved automatically');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Administrator\",\n    \"email\": \"{{admin_email}}\",\n    \"password\": \"{{admin_password}}\",\n    \"role\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": ["{{base_url}}"],
              "path": ["api", "register"]
            },
            "description": "Register a new admin user. The token is automatically saved to the collection variable `token`."
          }
        },
        {
          "name": "1.2 Register Anggota",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains access_token and anggota role', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.have.property('access_token');",
                  "    pm.expect(data.user.role).to.eql('anggota');",
                  "});",
                  "",
                  "// Save anggota token separately",
                  "var data = pm.response.json();",
                  "if (data.access_token) {",
                  "    pm.collectionVariables.set('anggota_token', data.access_token);",
                  "    console.log('✅ Anggota token saved automatically');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Anggota Perpustakaan\",\n    \"email\": \"{{anggota_email}}\",\n    \"password\": \"{{anggota_password}}\",\n    \"role\": \"anggota\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": ["{{base_url}}"],
              "path": ["api", "register"]
            },
            "description": "Register a new anggota (member) user. The token is saved to `anggota_token`."
          }
        },
        {
          "name": "1.3 Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Login successful with token', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.message).to.eql('Login successful');",
                  "    pm.expect(data).to.have.property('access_token');",
                  "    pm.expect(data.token_type).to.eql('Bearer');",
                  "});",
                  "",
                  "// Auto-save token for all subsequent requests",
                  "var data = pm.response.json();",
                  "if (data.access_token) {",
                  "    pm.collectionVariables.set('token', data.access_token);",
                  "    console.log('✅ Admin token updated: ' + data.access_token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{admin_email}}\",\n    \"password\": \"{{admin_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            },
            "description": "Login as admin. The token is automatically saved and all subsequent requests will use it via collection-level Bearer auth."
          }
        },
        {
          "name": "1.4 Login Anggota",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Login successful', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.message).to.eql('Login successful');",
                  "    pm.expect(data).to.have.property('access_token');",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data.access_token) {",
                  "    pm.collectionVariables.set('anggota_token', data.access_token);",
                  "    console.log('✅ Anggota token updated');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{anggota_email}}\",\n    \"password\": \"{{anggota_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            },
            "description": "Login as anggota. Token saved to `anggota_token` for member-specific tests."
          }
        },
        {
          "name": "1.5 Get User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains user data', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.have.property('id');",
                  "    pm.expect(data).to.have.property('name');",
                  "    pm.expect(data).to.have.property('email');",
                  "    pm.expect(data).to.have.property('role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user",
              "host": ["{{base_url}}"],
              "path": ["api", "user"]
            },
            "description": "Get the authenticated user's profile. Uses the collection-level Bearer token (admin by default)."
          }
        },
        {
          "name": "1.6 Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Logged out successfully', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.message).to.eql('Logged out successfully');",
                  "});",
                  "",
                  "// Note: After logout, you need to Login again to get a new token",
                  "console.log('⚠️ Token has been revoked. Run Login Admin again to get a new token.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "logout"]
            },
            "description": "Logout the current user and revoke the token. You will need to Login again after this."
          }
        }
      ]
    },
    {
      "name": "2. Buku (CRUD)",
      "description": "Full CRUD operations for books.\nRequires admin/petugas role for Create, Update, Delete.\nAll roles can Read (GET).",
      "item": [
        {
          "name": "2.1 Create Buku (1st book)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Buku created successfully', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.message).to.eql('Buku created successfully');",
                  "    pm.expect(data.data).to.have.property('id');",
                  "    pm.expect(data.data.judul).to.eql('Laskar Pelangi');",
                  "});",
                  "",
                  "// Auto-save buku_id for subsequent requests",
                  "var data = pm.response.json();",
                  "if (data.data && data.data.id) {",
                  "    pm.collectionVariables.set('buku_id', data.data.id);",
                  "    console.log('✅ buku_id saved: ' + data.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"kategori_id\": {{kategori_id}},\n    \"judul\": \"Laskar Pelangi\",\n    \"pengarang\": \"Andrea Hirata\",\n    \"penerbit\": \"Bentang Pustaka\",\n    \"tahun_terbit\": 2005,\n    \"isbn\": \"978-979-1227-00-2\",\n    \"stok\": 10\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/buku",
              "host": ["{{base_url}}"],
              "path": ["api", "buku"]
            },
            "description": "Create the first book. The `buku_id` is auto-saved for use in Get/Update/Delete."
          }
        },
